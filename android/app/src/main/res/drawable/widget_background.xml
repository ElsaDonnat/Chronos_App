<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer parchment fill (visible as beige margin around the border) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FAF6F0" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <!-- Inner card with burgundy border, inset to leave beige margin -->
    <item android:left="5dp" android:top="5dp" android:right="5dp" android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#FAF6F0" />
            <corners android:radius="24dp" />
            <stroke android:width="2dp" android:color="#8B4157" />
        </shape>
    </item>
</layer-list>
