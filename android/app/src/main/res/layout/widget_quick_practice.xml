<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_practice_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chronos"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#8B4157" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="▶ Quick Practice"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1C1917"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/practice_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 day streak"
            android:textSize="12sp"
            android:textColor="#6B7280" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  \u2022  "
            android:textSize="12sp"
            android:textColor="#6B7280" />

        <TextView
            android:id="@+id/practice_xp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 XP"
            android:textSize="12sp"
            android:textColor="#6B7280" />

    </LinearLayout>

</LinearLayout>
