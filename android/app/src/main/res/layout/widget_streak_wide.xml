<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_streak_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ViewFlipper
            android:id="@+id/flame_flipper"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:autoStart="true"
            android:flipInterval="1100">

            <ImageView
                android:id="@+id/flame_frame_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/flame_active_1"
                android:contentDescription="@null" />

            <ImageView
                android:id="@+id/flame_frame_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/flame_active_2"
                android:contentDescription="@null" />

        </ViewFlipper>

        <ImageView
            android:id="@+id/check_tick"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/widget_check_tick"
            android:visibility="gone"
            android:contentDescription="@null" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/streak_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#8B4157" />

        <TextView
            android:id="@+id/streak_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="day streak"
            android:textSize="12sp"
            android:textColor="#1C1917" />

    </LinearLayout>

</LinearLayout>
